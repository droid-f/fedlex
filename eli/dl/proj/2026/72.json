      "attributes": {
        "eventTitle": {
          "rdf:langString": {
            "de": [
              "Teilrevision des Bundesgesetzes über die Schweizerische Exportrisikoversicherung  (SERVG)"
            ],
            "it": [
              "Revisione parziale della legge sull’assicurazione contro i rischi delle esportazioni (LARE)"
            ],
            "fr": [
              "Révision partielle de la loi sur l’assurance suisse contre les risques à l’exportation (LASRE)"
            ]
          }
        },
        "eventDescription": {
          "rdf:langString": {
            "de": [
              "Gezielte Teilrevision des SERVG, um die Flexibilität bei den Produkten (Einführung; Anpassungen) und Versicherungsvoraussetzungen (administrative Entlastung; einfacherer Zugang für KMU) zu erhöhen."
            ],
            "it": [
              "Revisione parziale mirata della LARE volta ad aumentare la flessibilità dei prodotti (introduzione; adeguamenti) e delle condizioni di assicurazione (alleggerimento amministrativo; accesso facilitato per le PMI)."
            ],
            "fr": [
              "Révision partielle ciblée de la LASRE visant à accroître la flexibilité des produits (introduction; adaptations) et des conditions d’assurance (allègement administratif; accès facilité pour les PME)."
            ]
          }
        },

      "attributes": {
        "eventTitle": {
          "rdf:langString": {
            "de": [
              "Änderung des Bundesgesetzes über die Krankenversicherung (KVG): Mehrjahresverträge"
            ],
            "it": [
              "Modifica della legge federale sull’assicurazione malattie (LAMal): contratti pluriennali"
            ],
            "fr": [
              "Modification de la loi fédérale sur l’assurance-maladie (LAMal) : contrats pluriannuels"
            ]
          }
        },
        "eventDescription": {
          "rdf:langString": {
            "de": [
              "Der Entwurf sieht vor, dass die Versicherer mit den Versicherten freiwillige Mehrjahresverträge für Versicherungsformen mit eingeschränkter Wahl der Leistungserbringer abschliessen können."
            ],
            "it": [
              "Il progetto prevede di consentire agli assicuratori di stipulare con gli assicurati contratti pluriennali facoltativi per le forme di assicurazione con scelta limitata dei fornitori di prestazioni."
            ],
            "fr": [
              "Le projet consiste à permettre aux assureurs de conclure avec les assurés des contrats pluriannuels facultatifs pour les formes d’assurance impliquant un choix limité des fournisseurs de prestations."
            ]
          }
        },

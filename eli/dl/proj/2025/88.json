      "attributes": {
        "eventTitle": {
          "rdf:langString": {
            "de": [
              "Landwirtschaftliches Verordnungspaket 2026"
            ],
            "it": [
              "Pacchetto di ordinanze agricole 2026"
            ],
            "fr": [
              "Train d’ordonnances agricoles 2026"
            ]
          }
        },
        "eventDescription": {
          "rdf:langString": {
            "de": [
              "Die Vernehmlassungsvorlage enthält Anpassungen von 14 landwirtschaftlichen Verordnungen. Die Verordnungsänderungen, die am 1. Januar 2027 in Kraft treten, sollen den Verwaltungsaufwand für die Betriebe verringern."
            ],
            "it": [
              "Il progetto in consultazione comprende la modifica di 14 ordinanze agricole. Le modifiche di ordinanza, che entreranno in vigore il 1° gennaio 2027, mirano a ridurre l’onere amministrativo delle aziende."
            ],
            "fr": [
              "Le dossier de consultation comprend l’adaptation de 14 ordonnances agricoles. Les modifications d’ordonnances, valables à partir du 1er janvier 2027, visent à alléger la charge administrative des exploitations."
            ]
          }
        },
